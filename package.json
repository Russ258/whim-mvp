{
  "name": "whim-mvp",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @whim/mobile start",
    "server": "yarn workspace @whim/server dev",
    "lint": "eslint '**/*.{ts,tsx}' --ignore-path .gitignore",
    "format": "prettier --write '**/*.{ts,tsx,json,md}' --ignore-path .gitignore"
  },
  "devDependencies": {
    "@whim/eslint-config": "*",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
