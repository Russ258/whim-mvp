generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Salon {
  id                  Int                  @id @default(autoincrement())
  name                String
  description         String
  city                String
  address             String
  rating              Float                @default(4.7)
  distanceKm          Float
  heroImage           String?
  category            String               @default("HAIR")
  email               String?
  phone               String?
  createdAt           DateTime             @default(now())
  slots               DealSlot[]
  salonAccount        SalonAccount?
  services            Service[]
  availabilityWindows AvailabilityWindow[]
  reviews             Review[]
}

model SalonApplication {
  id              Int      @id @default(autoincrement())
  salonName       String
  contactName     String
  email           String
  phone           String
  address         String
  chairs          String?
  bookingSoftware String?
  notes           String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model SalonAccount {
  id          Int       @id @default(autoincrement())
  salonId     Int       @unique
  email       String    @unique
  loginToken  String    @unique
  tokenExpiry DateTime?
  createdAt   DateTime  @default(now())
  salon       Salon     @relation(fields: [salonId], references: [id])
}

model Service {
  id                  Int                  @id @default(autoincrement())
  name                String
  tier                String               @default("QUICK")
  durationMin         Int
  basePrice           Int
  salonId             Int
  slots               DealSlot[]
  salon               Salon                @relation(fields: [salonId], references: [id])
  availabilityWindows AvailabilityWindow[]
}

model AvailabilityWindow {
  id         Int      @id @default(autoincrement())
  salonId    Int
  serviceId  Int
  dayOfWeek  Int      // 0=Sun 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
  startHour  Int      // 0-23
  endHour    Int      // 0-23 exclusive
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  salon      Salon    @relation(fields: [salonId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])
}

model DealSlot {
  id              Int       @id @default(autoincrement())
  salonId         Int
  serviceId       Int
  startTime       DateTime
  endTime         DateTime
  discountPercent Int
  price           Int
  status          String    @default("AVAILABLE")
  createdAt       DateTime  @default(now())
  bookings        Booking[]
  salon           Salon     @relation(fields: [salonId], references: [id])
  service         Service   @relation(fields: [serviceId], references: [id])
}

model Booking {
  id            Int       @id @default(autoincrement())
  slotId        Int
  customerName  String
  customerEmail String
  status        String    @default("CONFIRMED")
  paymentStatus String    @default("PAID")
  notes         String?
  voucherCode        String    @unique
  appliedPromoCode   String?
  promoDiscountPct   Int?
  redeemedAt         DateTime?
  createdAt     DateTime  @default(now())
  slot          DealSlot  @relation(fields: [slotId], references: [id])
  review        Review?
}

model NotificationPreference {
  id        Int      @id @default(autoincrement())
  email     String
  wantsPush Boolean  @default(true)
  wantsSms  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PromoCode {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  description     String?
  discountPercent Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model PaymentMethod {
  id            Int     @id @default(autoincrement())
  customerEmail String
  brand         String
  last4         String
  expiryMonth   Int
  expiryYear    Int
  primary       Boolean @default(false)
}

model WaitlistEntry {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  promoCode   String   @unique
  earlyAccess Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Review {
  id              Int      @id @default(autoincrement())
  bookingId       Int      @unique
  salonId         Int
  customerEmail   String
  overallRating   Int      // 1-5
  valueRating     Int      // 1-5
  repeatRating    Int      // 1-5
  createdAt       DateTime @default(now())
  booking         Booking  @relation(fields: [bookingId], references: [id])
  salon           Salon    @relation(fields: [salonId], references: [id])
}
